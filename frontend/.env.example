# Axios baseURL — relative path goes through the Vite dev proxy.
# In production (Vercel), set this to the absolute backend URL:
#   VITE_API_URL=https://govlink.up.railway.app
VITE_API_URL=/api

# Where the Vite dev server proxies /api/* in development.
# To dev against the live Railway backend instead of a local API:
#   VITE_API_PROXY_TARGET=https://govlink.up.railway.app
VITE_API_PROXY_TARGET=http://localhost:8000

# Public-facing API URL shown in displayed snippets, Swagger / OpenAPI
# links, and error copy. In production:
#   VITE_API_PUBLIC_URL=https://govlink.up.railway.app
VITE_API_PUBLIC_URL=http://localhost:8000

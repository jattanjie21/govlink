# Application
GOVLINK_ENV=development              # development | production
GOVLINK_LOG_LEVEL=INFO

# Database — SQLite for local dev, Postgres for production
# Local SQLite example:
GOVLINK_DATABASE_URL=sqlite:///./govlink.db
# Production Postgres example:
# GOVLINK_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/govlink

# Raw file storage (where downloaded PDFs are kept)
GOVLINK_RAW_DATA_DIR=./data/raw

# API
GOVLINK_API_HOST=0.0.0.0
GOVLINK_API_PORT=8000
GOVLINK_RATE_LIMIT_PER_MINUTE=60

# CORS (comma-separated)
GOVLINK_CORS_ORIGINS=*
